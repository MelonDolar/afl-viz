{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Points For vs Against - AFL 2024",
  "data": {"url": "data/team_info.csv"},
  "layer": [
    {
      "mark": {"type": "rule", "strokeDash": [6, 3], "stroke": "#555", "strokeWidth": 1},
      "encoding": {
        "x": {"datum": 92},
        "x2": {"datum": 92}
      }
    },
    {
      "mark": {"type": "rule", "strokeDash": [6, 3], "stroke": "#555", "strokeWidth": 1},
      "encoding": {
        "y": {"datum": 92}
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 120,
        "opacity": 0.85
      },
      "encoding": {
        "x": {
          "field": "points_for_avg",
          "type": "quantitative",
          "axis": {
            "title": "Average Points For",
            "titleColor": "#e0e0e0",
            "labelColor": "#e0e0e0",
            "gridColor": "#333"
          },
          "scale": {"domain": [60, 115]}
        },
        "y": {
          "field": "points_against_avg",
          "type": "quantitative",
          "axis": {
            "title": "Average Points Against",
            "titleColor": "#e0e0e0",
            "labelColor": "#e0e0e0",
            "gridColor": "#333"
          },
          "scale": {"domain": [78, 108]}
        },
        "color": {
          "field": "wins_2024",
          "type": "quantitative",
          "scale": {
            "domain": [5, 18],
            "range": ["#c0392b", "#f39c12", "#27ae60"]
          },
          "legend": {
            "title": "Wins",
            "labelColor": "#e0e0e0",
            "titleColor": "#e0e0e0"
          }
        },
        "tooltip": [
          {"field": "team", "type": "nominal", "title": "Team"},
          {"field": "points_for_avg", "type": "quantitative", "title": "Avg Points For", "format": ".1f"},
          {"field": "points_against_avg", "type": "quantitative", "title": "Avg Points Against", "format": ".1f"},
          {"field": "wins_2024", "type": "quantitative", "title": "Wins"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "dy": -10,
        "fontSize": 10,
        "fontWeight": "bold"
      },
      "encoding": {
        "x": {"field": "points_for_avg", "type": "quantitative"},
        "y": {"field": "points_against_avg", "type": "quantitative"},
        "text": {"field": "team", "type": "nominal"},
        "color": {"value": "#ccc"}
      }
    }
  ],
  "background": "transparent",
  "config": {
    "view": {"stroke": null},
    "axis": {"domainColor": "#555", "tickColor": "#555"}
  }
}
